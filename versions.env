# Version pins: override at runtime via env vars.
# All *_VERSION variables can be set in compose.yaml, k8s/configmap.yaml,
# or as docker run -e flags.
#
# PI coding agent
PI_VERSION=0.80.2

# Go
GO_VERSION=1.26.4

# Go tools
GOPLS_VERSION=v0.22.0
SQLC_VERSION=v1.31.1
GORELEASER_VERSION=v2.11.0
PROTOC_GEN_GO_VERSION=v1.36.11
PROTOC_GEN_CONNECT_GO_VERSION=v1.20.0

# Standalone CLI tools
RG_VERSION=15.1.0
FD_VERSION=10.4.2
GH_VERSION=2.95.0
BUF_VERSION=1.71.0

# Optional tools (set INSTALL_ZIG=true to enable)
ZIG_VERSION=0.14.0

# Extension mechanisms (space-separated):
# EXTRA_APT_PACKAGES="htop tmux vim"
# EXTRA_BUN_PACKAGES="typescript ts-node"
# EXTRA_GO_BIN="honnef.co/go/tools/cmd/staticcheck@latest"
# EXTRA_CURL_BIN="https://example.com/tool:mytool"